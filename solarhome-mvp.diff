+  if (!res.ok) throw new Error('List failed');
+  return res.json();
+}
+
+export function downloadPdf(projectId: string) {
+  const url = `/api/projects/pdf?id=${encodeURIComponent(projectId)}`;
+  window.open(url, '_blank');
