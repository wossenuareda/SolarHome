+      setProjects(res.projects || []);
+    } catch (err) {
+      console.error(err);
+      alert('Failed to load projects');
+    } finally {
+      setLoading(false);
+    }
+  };
+
+  useEffect(() => { load(); }, [user]);
+
+  const archive = async (id: string) => {
+    const r = await fetch('/api/projects/archive', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
